# ================================================================
# AutoQAI — SECRETS-ONLY environment file
# ================================================================
#
# Runtime configuration (ports, browser driver, LLM task bindings, Jira
# base URL, Swagger feeds, feature flags, resolution presets, etc.) now
# lives in `config.json` at the repo root.
#
# Only credentials and deployment overrides belong here.
# ================================================================

# ================================================================
# LLM PROVIDER CREDENTIALS
# ================================================================
# OpenAI
OPENAI_API_KEY=sk-...

# AWS Bedrock (SDK) — region is in config.json under llm.providers.bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Bedrock (REST API) — region + anthropicVersion are in config.json
BED_ROCK_API_KEY=

# GitHub Copilot CLI — authenticate with `copilot auth login` (no token here)
# Claude Code CLI      — authenticate with `claude auth` or set ANTHROPIC_API_KEY below
# ANTHROPIC_API_KEY=   # optional, only if you run Claude Code in SDK-API mode

# ================================================================
# JIRA INTEGRATION
# ================================================================
# Base URL lives in config.json under integrations.jira.baseUrl;
# only the credentials stay here.
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-token

# ================================================================
# RUNTIME OVERRIDES (optional)
# ================================================================
# Override config.json search path. First location wins.
# AUTOQAI_CONFIG_PATH=/absolute/path/to/config.json

# Override backend base URL for the activator (defaults to config.json's backend port).
# BACKEND_URL=http://localhost:7000

# Override the initial URL the browser opens on launch (overrides config.json).
# LAUNCH_URL=

# ================================================================
# UI BUILD-TIME OVERRIDES (Vite — VITE_*)
# ================================================================
# These are compiled INTO the static build. Override only if the UI is
# served from a different origin than the activator / backend (e.g. a
# CDN-hosted UI talking to a remote activator).
#
# Activator WebSocket URL. Defaults to ws://localhost:7001.
# VITE_ACTIVATOR_URL=ws://localhost:7001
